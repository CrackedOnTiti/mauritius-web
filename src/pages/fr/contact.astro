---
import Layout from '../../layouts/Layout.astro';
import { fetchProperties } from '../../data/properties';
import { t } from '../../i18n/translations';

const locale = 'fr';
const properties = await fetchProperties();
---

<Layout locale={locale} title={t(locale, 'nav.contact')}>
  <section class="page-hero">
    <div class="container">
      <h1>{t(locale, 'contact.title')}</h1>
      <p>{t(locale, 'contact.subtitle')}</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container contact-grid">
      <div class="contact-form-wrapper">
        <form
          id="contact-form"
          action="/api/contact"
          method="POST"
          class="contact-form"
        >
          <input type="hidden" name="locale" value={locale} />

          <div class="form-row">
            <div class="form-field">
              <label for="name">{t(locale, 'contact.name')} *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-field">
              <label for="email">{t(locale, 'contact.email')} *</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="phone">{t(locale, 'contact.phone')}</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            <div class="form-field">
              <label for="property">{t(locale, 'contact.property')}</label>
              <select id="property" name="property">
                <option value="">{t(locale, 'contact.property_any')}</option>
                {properties.map((p) => (
                  <option value={p.slug}>{p.name[locale]}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="checkin">{t(locale, 'contact.checkin')}</label>
              <input type="date" id="checkin" name="checkin" />
            </div>
            <div class="form-field">
              <label for="checkout">{t(locale, 'contact.checkout')}</label>
              <input type="date" id="checkout" name="checkout" />
            </div>
          </div>

          <div class="form-field">
            <label for="guests">{t(locale, 'contact.guests')}</label>
            <input type="number" id="guests" name="guests" min="1" max="20" />
          </div>

          <div class="form-field">
            <label for="message">{t(locale, 'contact.message')} *</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder={t(locale, 'contact.message_placeholder')}
            ></textarea>
          </div>

          <div id="form-status" class="form-status" aria-live="polite"></div>

          <button type="submit" class="btn btn-primary submit-btn">
            {t(locale, 'contact.send')}
          </button>
        </form>
      </div>

      <aside class="contact-sidebar">
        <div class="contact-info-card">
          <h3>Contact Direct</h3>
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}`}
            class="btn btn-whatsapp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {t(locale, 'contact.whatsapp')}
          </a>
          <div class="map-placeholder">
            <!-- Replace with Google Maps embed -->
            <div class="map-fallback">
              <span>Localisation</span>
              <p>Côte Ouest, Île Maurice</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';
    status.className = 'form-status';
    status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        status.className = 'form-status success';
        status.textContent = 'Message envoyé ! Nous vous répondrons sous 24 heures.';
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      status.className = 'form-status error';
      status.textContent = 'Une erreur s\'est produite. Veuillez réessayer ou nous contacter sur WhatsApp.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer le Message';
    }
  });
</script>

<style>
  .page-hero {
    background: var(--color-bg-alt);
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .contact-section { padding: 4rem 0 6rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    padding: 0.7rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: var(--color-white);
    transition: border-color 0.2s;
    outline: none;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(14, 116, 144, 0.1);
  }

  .form-field textarea { resize: vertical; }

  .form-status {
    padding: 0.9rem 1.25rem;
    border-radius: 8px;
    font-size: 0.95rem;
    display: none;
  }

  .form-status.success {
    display: block;
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  .form-status.error {
    display: block;
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  .submit-btn { align-self: flex-start; padding: 0.85rem 2.5rem; }

  .contact-info-card {
    background: var(--color-white);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 90px;
  }

  .contact-info-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .map-placeholder {
    height: 220px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .map-fallback {
    width: 100%;
    height: 100%;
    background: var(--color-bg-alt);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 2.5rem;
    color: var(--color-text-muted);
  }

  .map-fallback p {
    font-size: 0.9rem;
    font-family: var(--font-body);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-info-card { position: static; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
