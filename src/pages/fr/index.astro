---
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import Activities from '../../components/Activities.astro';
import { fetchProperties } from '../../data/properties';
import { t } from '../../i18n/translations';

const locale = 'fr';
const properties = await fetchProperties();
---

<Layout locale={locale}>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <p class="hero-eyebrow">Côte Ouest, Île Maurice</p>
      <h1>{t(locale, 'hero.tagline')}</h1>
      <p class="hero-subtitle">{t(locale, 'hero.subtitle')}</p>
      <div class="hero-actions">
        <a href="/fr/properties/" class="btn btn-primary">{t(locale, 'hero.cta')}</a>
        <a
          href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}`}
          class="btn btn-whatsapp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t(locale, 'contact.whatsapp')}
        </a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>↓</span>
    </div>
  </section>

  <!-- Properties -->
  <section class="properties-section">
    <div class="container">
      <div class="section-header">
        <h2>{t(locale, 'properties.title')}</h2>
        <p>{t(locale, 'properties.subtitle')}</p>
      </div>
      <div class="properties-grid">
        {properties.map((p) => <PropertyCard property={p} locale={locale} />)}
      </div>
    </div>
  </section>

  <Activities locale={locale} />

  <!-- About -->
  <section class="about-section">
    <div class="container about-inner">
      <div class="about-image">
        <div class="about-image-placeholder"></div>
      </div>
      <div class="about-text">
        <h2>{t(locale, 'about.title')}</h2>
        <p>{t(locale, 'about.body')}</p>
        <a href="/fr/contact/" class="btn btn-outline">{t(locale, 'nav.contact')}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.55) 100%),
      url('https://picsum.photos/seed/tropical-beach/1600/900');
    background-size: cover;
    background-position: center;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: white;
    max-width: 700px;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .hero-eyebrow {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    opacity: 0.9;
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: white;
    opacity: 0.6;
    font-size: 1.5rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  .properties-section { background: var(--color-bg); }

  .properties-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .about-section { background: var(--color-bg-alt); }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-image-placeholder {
    height: 420px;
    border-radius: var(--radius);
    background: linear-gradient(135deg, #0e7490, #06b6d4);
  }

  .about-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
  }

  .about-text p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  @media (max-width: 768px) {
    .about-inner { grid-template-columns: 1fr; gap: 2rem; }
    .about-image { order: -1; }
    .about-image-placeholder { height: 260px; }
  }
</style>
